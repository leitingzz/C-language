{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C: gcc.exe 编译整个项目",
            "command": "C:/msys64/ucrt64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wall",
                "${fileDirname}\\main.c",
                "${fileDirname}\\student.c",
                "${fileDirname}\\file_io.c",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译整个项目的所有.c文件"
        }
    ],
    "version": "2.0.0"
}